{
    "extends": "@tada5hi/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "noPropertyAccessFromIndexSignature": false,
        "esModuleInterop": true
    },
    "include": [
        "src/**/*"
    ]
}
