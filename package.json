{
    "name": "locter",
    "version": "4.1.0",
    "type": "module",
    "description": "A library to locate files/modules by criteria, read them and write them back!",
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/locter.git"
    },
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build:types": "tsc --noEmit",
        "build:js": "tsdown",
        "build": "npm run build:types && npm run build:js",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix",
        "prepare": "husky"
    },
    "keywords": [
        "file",
        "locator",
        "loader",
        "reader",
        "writer",
        "loading",
        "on-demand-transpiling",
        "transpiling",
        "file-extension",
        "typescript",
        "json",
        "yaml",
        "conf"
    ],
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "devDependencies": {
        "@tada5hi/commitlint-config": "^1.3.1",
        "@tada5hi/eslint-config": "^2.3.1",
        "@tada5hi/tsconfig": "^0.7.2",
        "@vitest/coverage-v8": "^4.1.10",
        "eslint": "^10.7.0",
        "husky": "^9.1.7",
        "tsdown": "^0.22.8",
        "typescript": "^7.0.2",
        "typescript-eslint": "^8.64.0",
        "vitest": "^4.1.5"
    },
    "dependencies": {
        "@ebec/core": "^1.1.0",
        "destr": "^2.0.5",
        "fast-glob": "^3.3.3",
        "flat": "^6.0.1",
        "jiti": "^2.6.1",
        "yaml": "^2.8.1"
    }
}
